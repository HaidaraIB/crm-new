# CRM web app — copy to .env and fill in values (see README)

# JSON API root (recommended: /api/v1). No trailing slash.
# Examples: http://127.0.0.1:8000/api/v1   https://api.example.com/api/v1
VITE_API_URL=http://127.0.0.1:8000/api/v1

# Must match API_KEY_WEB on the Django API (X-API-Key header for protected /api/* routes).
VITE_API_KEY_WEB=

# Optional fallback if you still use the old variable name
# VITE_API_KEY=

# Optional: subdomain routing (see utils/routing.ts)
# VITE_BASE_DOMAIN=dashboard.loop-crm.app

# Optional: Gemini
# GEMINI_API_KEY=
